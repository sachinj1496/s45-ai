# Copy to `.env` in the project root (same directory as `main.py`).
# Variables already set in the shell take precedence over `.env`.

# Required: `pytest` fails if this is empty after loading `.env`.
OPENAI_API_KEY=
OPENAI_API_BASE=https://api.openai.com
OPENAI_MODEL=gpt-4o-mini
LLM_MAX_ATTEMPTS=6

# Optional: `1` routes `data/raw_data` into structured folders when running `main.py`.
# ROUTE_FROM_RAW=1
